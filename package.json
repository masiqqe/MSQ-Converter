{
  "name": "msq-converter",
  "version": "1.0.1",
  "description": "MSQ Converter — fast and free file converter for Windows",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": [],
  "author": "masiqqe",
  "license": "GPL-3.0",
  "type": "commonjs",
  "build": {
    "appId": "ru.masiqqe.msqconverter",
    "productName": "MSQ Converter",
    "copyright": "Copyright © 2026 masiqqe",
    "win": {
      "target": "msi",
      "icon": "src/assets/icon.ico"
    },
    "msi": {
      "oneClick": false,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/assets",
        "to": "assets"
      }
    ],
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^36.3.1",
    "electron-builder": "^26.0.12",
    "png-to-ico": "^3.0.1"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "sharp": "^0.35.1"
  }
}
